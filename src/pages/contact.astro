---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceHero from '../components/ServiceHero.astro';

// Aspire contact form created via DE's JotForm API workflow.
// Form lives at https://www.jotform.com/build/261376609844164 — the form posts
// directly to JotForm's submit endpoint via a hidden iframe so the page doesn't redirect.
const JOTFORM_ID = '261376609844164';

const address = {
  street: '14112 Darnestown Road',
  city: 'Germantown, MD 20874',
  mapHref: 'https://maps.app.goo.gl/N2PvSD3aSu1r6CRc9',
};
const phone = '301-366-0040';
const phoneDisplay = '(301) 366-0040';
const email = 'info@aspirevethospital.com';

const hours = [
  { day: 'Monday',    time: '8am – 6pm' },
  { day: 'Tuesday',   time: '8am – 6pm' },
  { day: 'Wednesday', time: '8am – 6pm' },
  { day: 'Thursday',  time: '8am – 6pm' },
  { day: 'Friday',    time: '8am – 6pm' },
  { day: 'Saturday',  time: '9am – 1pm' },
  { day: 'Sunday',    time: 'Closed' },
];

const schemaJson = `{"@context":"https://schema.org","@type":"VeterinaryCare","name":"Aspire Veterinary Hospital","url":"https://aspirevethospital.com/","telephone":"+1-301-366-0040","email":"info@aspirevethospital.com","address":{"@type":"PostalAddress","streetAddress":"14112 Darnestown Road","addressLocality":"Germantown","addressRegion":"MD","postalCode":"20874","addressCountry":"US"},"openingHoursSpecification":[{"@type":"OpeningHoursSpecification","dayOfWeek":["Monday","Tuesday","Wednesday","Thursday","Friday"],"opens":"08:00","closes":"18:00"},{"@type":"OpeningHoursSpecification","dayOfWeek":"Saturday","opens":"09:00","closes":"13:00"}]}`;
---

<BaseLayout
  title="Contact Aspire Veterinary Hospital in Germantown, MD"
  description="Reach Aspire Veterinary Hospital — address, phone, hours, directions, and contact form. Located at 14112 Darnestown Road, Germantown, MD."
  canonical="https://aspirevethospital.com/contact/"
  ogImage="/contact-hero.jpg"
  ogType="website"
  schemaJson={schemaJson}
>
  <ServiceHero
    bgImage="/contact-hero.jpg"
    eyebrow="Aspire Veterinary Hospital"
    h1="Contact Us"
    lede="Reach out for appointments, questions, or directions to the hospital."
  />

  <!-- INFO + FORM — two-column grid on navy: info cards on the left, JotForm on the right -->
  <section class="contact-info">
    <div class="contact-info__inner">
      <div class="contact-info__cards">
        <div class="info-card">
          <h3 class="info-card__title">
            <svg class="info-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            Address
          </h3>
          <p>
            <a href={address.mapHref} target="_blank" rel="noopener noreferrer">
              {address.street}<br />
              {address.city}
            </a>
          </p>
          <p class="info-card__action">
            <a href={address.mapHref} target="_blank" rel="noopener noreferrer">Get Directions →</a>
          </p>
        </div>

        <div class="info-card">
          <h3 class="info-card__title">
            <svg class="info-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Phone & Email
          </h3>
          <p><a href={`tel:${phone}`}>{phoneDisplay}</a></p>
          <p><a href={`mailto:${email}`}>{email}</a></p>
        </div>

        <div class="info-card">
          <h3 class="info-card__title">
            <svg class="info-card__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
            Hours
          </h3>
          <ul class="hours-list">
            {hours.map((h) => (
              <li>
                <span class="hours-list__day">{h.day}</span>
                <span class="hours-list__time">{h.time}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>

      <div class="contact-info__form">
        <h2 class="contact-info__form-title">Send Us a Message</h2>
        <p class="contact-info__form-lede">Have a question or need to reach the team? Fill out the form and we'll be in touch.</p>

        <div class="contact-form-embed">
          <form
            class="aspire-form"
            id="aspire-contact-form"
            action={`https://submit.jotform.com/submit/${JOTFORM_ID}`}
            method="POST"
            target="jotform-submit"
            novalidate
          >
            <div class="aspire-form__row">
              <label class="aspire-form__field">
                <span class="aspire-form__label">Full Name <span class="aspire-form__req" aria-hidden="true">*</span></span>
                <input class="aspire-form__input" type="text" name="q4_fullName" required autocomplete="name" />
              </label>
            </div>

            <div class="aspire-form__row aspire-form__row--two">
              <label class="aspire-form__field">
                <span class="aspire-form__label">Email <span class="aspire-form__req" aria-hidden="true">*</span></span>
                <input class="aspire-form__input" type="email" name="q3_email" required autocomplete="email" />
              </label>
              <label class="aspire-form__field">
                <span class="aspire-form__label">Phone <span class="aspire-form__req" aria-hidden="true">*</span></span>
                <input class="aspire-form__input" type="tel" name="q2_phone" required autocomplete="tel" inputmode="tel" />
              </label>
            </div>

            <div class="aspire-form__row">
              <label class="aspire-form__field">
                <span class="aspire-form__label">Pet Name <span class="aspire-form__optional">(optional)</span></span>
                <input class="aspire-form__input" type="text" name="q6_petName" autocomplete="off" />
              </label>
            </div>

            <div class="aspire-form__row">
              <label class="aspire-form__field">
                <span class="aspire-form__label">Reason for Contact <span class="aspire-form__req" aria-hidden="true">*</span></span>
                <select class="aspire-form__input aspire-form__select" name="q1_reasonForContact" required>
                  <option value="" disabled selected>Select a reason...</option>
                  <option value="General Question">General Question</option>
                  <option value="New Client Inquiry">New Client Inquiry</option>
                  <option value="Appointment Request">Appointment Request</option>
                  <option value="Prescription Refill">Prescription Refill</option>
                  <option value="Medical Records Request">Medical Records Request</option>
                  <option value="Feedback">Feedback</option>
                  <option value="Other">Other</option>
                </select>
              </label>
            </div>

            <div class="aspire-form__row">
              <label class="aspire-form__field">
                <span class="aspire-form__label">Message <span class="aspire-form__req" aria-hidden="true">*</span></span>
                <textarea class="aspire-form__input aspire-form__textarea" name="q5_message" rows="5" required placeholder="Share as much detail as you'd like — we'll get back to you within one business day."></textarea>
              </label>
            </div>

            <button class="aspire-form__submit" type="submit">Send Message</button>

            <p class="aspire-form__legal" id="aspire-form-status" role="status" aria-live="polite"></p>
          </form>

          <div class="aspire-form__success" id="aspire-form-success" hidden>
            <h3>Thanks — we received your message.</h3>
            <p>A member of our team will reach out within one business day during our regular hours.</p>
            <p class="aspire-form__success-note">
              <strong>Medical emergency?</strong> Please call us directly at <a href={`tel:${phone}`}>{phoneDisplay}</a> or visit your nearest emergency veterinary hospital. This form is not monitored after hours.
            </p>
          </div>

          {/* Hidden iframe receives the POST response so the page doesn't redirect to JotForm. */}
          <iframe name="jotform-submit" id="jotform-submit-iframe" title="form submit target" aria-hidden="true" tabindex="-1" style="display:none;"></iframe>

          <noscript>
            <p style="margin-top:16px;">If the form doesn't submit, please email <a href={`mailto:${email}`}>{email}</a> or call <a href={`tel:${phone}`}>{phoneDisplay}</a>.</p>
          </noscript>
        </div>
      </div>
    </div>
  </section>

  <!-- MAP SECTION — full-bleed map, flush between the navy section above and footer below -->
  <section class="contact-map-section" aria-label="Map to Aspire Veterinary Hospital">
    <iframe
      class="contact-map-section__map"
      title="Map to Aspire Veterinary Hospital"
      src="https://www.google.com/maps?q=14112+Darnestown+Road+Germantown+MD+20874&t=&z=15&ie=UTF8&iwloc=&output=embed"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
    ></iframe>
  </section>
</BaseLayout>

<style>
  /* ===== INFO + FORM (navy) ===== */
  .contact-info {
    background: var(--aspire-navy);
    padding: 80px 0;
  }
  .contact-info__inner {
    max-width: var(--container);
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    /* Cards column narrower; form column wider since the form is the
       primary action and visually dominant. */
    grid-template-columns: 360px 1fr;
    gap: 40px;
    align-items: stretch;
  }
  .contact-info__cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .info-card {
    background: #FFFFFF;
    border: 1px solid #ECE6DF;
    border-radius: 10px;
    padding: 22px 24px;
    flex: 1; /* fill the cards column so total height matches the form */
    display: flex;
    flex-direction: column;
  }
  .info-card__title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 500;
    color: var(--aspire-text-dark);
    margin: 0 0 12px;
    padding-bottom: 10px;
    border-bottom: 1px solid #ECE6DF;
  }
  .info-card__icon {
    width: 20px;
    height: 20px;
    color: var(--aspire-tan);
    flex-shrink: 0;
  }
  .info-card p {
    margin: 0 0 8px;
    font-size: 16px;
    line-height: 1.6;
    color: var(--aspire-text);
  }
  .info-card p:last-child { margin-bottom: 0; }
  .info-card a {
    color: var(--aspire-text);
    text-decoration: underline;
  }
  .info-card a:hover { color: var(--aspire-tan); }
  .info-card__action a {
    color: var(--aspire-tan);
    font-weight: 600;
    text-decoration: none;
  }
  .info-card__action a:hover { text-decoration: underline; }

  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 15px;
  }
  .hours-list li {
    display: flex;
    justify-content: space-between;
    padding: 4px 0;
    color: var(--aspire-text);
    border-bottom: 1px dashed #ECE6DF;
  }
  .hours-list li:last-child { border-bottom: 0; }
  .hours-list__day { font-weight: 500; color: var(--aspire-text-dark); }

  /* Form column — sits on navy, wrapped in a white card for legibility.
     Stretches to fill height so the form card matches the cards column. */
  .contact-info__form {
    background: #FFFFFF;
    border: 1px solid #ECE6DF;
    border-radius: 10px;
    padding: 32px;
    display: flex;
    flex-direction: column;
  }
  .contact-info__form-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 500;
    color: var(--aspire-tan);
    margin: 0 0 8px;
  }
  .contact-info__form-lede {
    margin: 0 0 20px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--aspire-text);
  }
  .contact-form-embed {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* ----- Custom Aspire form ----- */
  .aspire-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .aspire-form__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  .aspire-form__row--two { grid-template-columns: 1fr 1fr; }
  @media (max-width: 600px) {
    .aspire-form__row--two { grid-template-columns: 1fr; }
  }
  .aspire-form__field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .aspire-form__label {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--aspire-text-dark);
    letter-spacing: 0.2px;
  }
  .aspire-form__req { color: var(--aspire-tan); margin-left: 2px; }
  .aspire-form__optional {
    color: var(--aspire-text);
    font-weight: 400;
    font-size: 12px;
    margin-left: 4px;
  }
  .aspire-form__input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #ECE6DF;
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 16px;
    color: var(--aspire-text-dark);
    background: #FFFFFF;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .aspire-form__input:focus {
    outline: none;
    border-color: var(--aspire-tan);
    box-shadow: 0 0 0 3px rgba(179, 151, 123, 0.15);
  }
  .aspire-form__input::placeholder { color: #AAAAAA; }
  .aspire-form__textarea {
    resize: vertical;
    min-height: 110px;
    line-height: 1.5;
  }
  .aspire-form__select {
    appearance: none;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='%23B3977B' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
    background-repeat: no-repeat;
    background-position: right 14px center;
    background-size: 14px 14px;
    padding-right: 38px;
  }
  /* Only show the error state after the user has actually interacted with the field —
     :user-invalid avoids the page-load flash that :invalid would trigger on required
     empty inputs. Older browsers fall through to the .is-error class we set via JS. */
  .aspire-form__input:user-invalid,
  .aspire-form__select.is-error,
  .aspire-form__input.is-error {
    border-color: #C84545;
    box-shadow: 0 0 0 3px rgba(200, 69, 69, 0.12);
  }

  .aspire-form__submit {
    margin-top: 4px;
    background: var(--aspire-navy);
    color: var(--aspire-cream);
    border: 1px solid var(--aspire-cream);
    border-radius: 5px;
    padding: 14px 28px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 300;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: background 0.25s, color 0.25s, opacity 0.2s;
    align-self: flex-start;
  }
  .aspire-form__submit:hover {
    background: var(--aspire-cream);
    color: var(--aspire-navy);
  }
  .aspire-form__submit:disabled {
    opacity: 0.6;
    cursor: wait;
  }
  .aspire-form__legal {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--aspire-text);
    min-height: 18px;
  }
  .aspire-form__legal.is-error { color: #C84545; font-weight: 500; }

  /* Success state shown after submit */
  .aspire-form__success {
    padding: 28px 24px;
    background: var(--aspire-section-bg);
    border-radius: 8px;
    border-left: 4px solid var(--aspire-tan);
  }
  .aspire-form__success h3 {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--aspire-tan);
  }
  .aspire-form__success p {
    margin: 0 0 10px;
    color: var(--aspire-text);
    line-height: 1.55;
  }
  .aspire-form__success p:last-child { margin-bottom: 0; }
  .aspire-form__success-note {
    margin-top: 16px !important;
    padding-top: 14px;
    border-top: 1px solid #ECE6DF;
    font-size: 14px;
  }
  .aspire-form__success-note strong { color: var(--aspire-navy); }

  @media (max-width: 960px) {
    .contact-info__inner { grid-template-columns: 1fr; }
    .info-card { flex: 0 1 auto; }  /* on mobile, don't force equal heights */
  }

  /* ===== MAP SECTION — true full-bleed, edge-to-edge ===== */
  .contact-map-section {
    margin: 0;
    padding: 0;
    line-height: 0; /* removes inline-baseline whitespace below the iframe */
  }
  .contact-map-section__map {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 7;
    border: 0;
  }
  @media (max-width: 720px) {
    .contact-map-section__map { aspect-ratio: 4 / 3; }
  }
</style>

<script>
  // Custom contact form -> JotForm via hidden iframe.
  // Form posts to submit.jotform.com which loads the JotForm thank-you page into the
  // hidden iframe. We detect that iframe-load event and swap the form for our own
  // success message (so the user never sees JotForm's branded thank-you).
  (function () {
    const form    = document.getElementById('aspire-contact-form') as HTMLFormElement | null;
    const iframe  = document.getElementById('jotform-submit-iframe') as HTMLIFrameElement | null;
    const success = document.getElementById('aspire-form-success') as HTMLElement | null;
    const status  = document.getElementById('aspire-form-status') as HTMLElement | null;
    if (!form || !iframe || !success || !status) return;

    let submitting = false;

    form.addEventListener('submit', () => {
      if (submitting) return;
      // Native HTML5 validation handles required/email/etc.
      if (!form.checkValidity()) return;

      submitting = true;
      const btn = form.querySelector<HTMLButtonElement>('.aspire-form__submit');
      if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }
      status.textContent = 'Sending your message...';
      status.classList.remove('is-error');
    });

    // The iframe fires `load` twice: once on initial render (empty about:blank — skip)
    // and again after the form POSTs to JotForm. The second load is our success signal.
    let iframeLoadCount = 0;
    iframe.addEventListener('load', () => {
      iframeLoadCount++;
      if (iframeLoadCount === 1) return;       // initial blank load
      if (!submitting) return;                  // unrelated reload

      form.hidden = true;
      success.hidden = false;
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });

      // Reset state in case the user wants to send another message.
      submitting = false;
    });
  })();
</script>
