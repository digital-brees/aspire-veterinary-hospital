<ServiceLayout
  title="Retired Working K9 Care in Germantown, MD | Aspire Veterinary Hospital"
  description="Comprehensive veterinary care for retired working and sporting canines — orthopedic, neurologic, chronic disease management, and compassionate end-of-life care."
  canonical="https://aspirevethospital.com/retired-k9-care-germantown-md/"
  ogImage="https://aspirevethospital.com/wp-content/uploads/2026/02/Retired_care_hero-1.jpg"
