---
// JobToggle.astro — collapsible accordion section, matches live Avada fusion-toggle.
// Click the title to expand/collapse. Defaults to closed.
export interface Props {
  title: string;
  open?: boolean;
}
const { title, open = false } = Astro.props;

// Stable, slug-style id derived from the title so screen readers can link the
// button to its content via aria-controls. Falls back to a random suffix when
// two toggles share a title on the same page.
const slugBase = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const baseId = `toggle-${slugBase || Math.random().toString(36).slice(2, 9)}`;
const btnId = `${baseId}-btn`;
const bodyId = `${baseId}-body`;
---

<div class="toggle" data-open={open ? 'true' : 'false'}>
  <button id={btnId} class="toggle__btn" type="button" aria-expanded={open ? 'true' : 'false'} aria-controls={bodyId}>
    <span class="toggle__title">{title}</span>
    <span class="toggle__icon" aria-hidden="true"></span>
  </button>
  <div id={bodyId} class="toggle__body" role="region" aria-labelledby={btnId} hidden={!open}>
    <div class="toggle__body-inner">
      <slot />
    </div>
  </div>
</div>

<style>
  .toggle {
    border: 1px solid #ECE6DF;
    border-radius: 6px;
    margin: 14px 0;
    background: #fff;
    overflow: hidden;
  }
  .toggle__btn {
    width: 100%;
    background: transparent;
    border: 0;
    padding: 18px 24px;
    text-align: left;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 500;
    color: var(--aspire-text-dark);
    transition: background 0.2s ease;
  }
  .toggle__btn:hover { background: #FAF8F4; }
  .toggle__btn:focus-visible {
    outline: 2px solid var(--aspire-tan);
    outline-offset: -2px;
  }
  .toggle__title { line-height: 1.3; }

  /* +/- icon: two lines, vertical one rotates+hides on open */
  .toggle__icon {
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--aspire-tan);
    position: relative;
  }
  .toggle__icon::before,
  .toggle__icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    top: 50%;
    left: 50%;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .toggle__icon::before {
    width: 16px;
    height: 2px;
    transform: translate(-50%, -50%);
  }
  .toggle__icon::after {
    width: 2px;
    height: 16px;
    transform: translate(-50%, -50%);
  }
  [data-open="true"] .toggle__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
    opacity: 0;
  }

  .toggle__body {
    overflow: hidden;
    transition: height 0.35s ease;
  }
  .toggle__body[hidden] { display: none; }

  .toggle__body-inner {
    padding: 4px 24px 24px;
  }
  /* Trim first/last child margins so spacing reads cleanly. */
  .toggle__body-inner > :first-child { margin-top: 0; }
  .toggle__body-inner > :last-child { margin-bottom: 0; }

  /* Lists inside any toggle pick up paw-icon bullets — matches live Avada
     fusion-toggle behavior. Job pages may layer their own list styling on top
     via JobPageLayout :global rules; this is the fallback for service pages. */
  .toggle__body-inner :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0 0 12px;
  }
  .toggle__body-inner :global(ul ul) {
    margin: 6px 0 6px 8px;
  }
  .toggle__body-inner :global(li) {
    position: relative;
    padding: 4px 0 4px 28px;
    font-size: 16px;
    line-height: 1.65;
    color: var(--aspire-text);
  }
  .toggle__body-inner :global(li::before) {
    content: "";
    position: absolute;
    left: 0;
    top: 14px;
    width: 14px;
    height: 14px;
    background-image: url('https://aspirevethospital.com/wp-content/uploads/2025/10/paw-icon.png');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }
</style>

<script>
  // Animated open/close using height transitions.
  // We can't transition `max-height: 0 → auto` directly, so we measure and set explicit heights.
  document.querySelectorAll<HTMLElement>('.toggle').forEach((toggle) => {
    const btn = toggle.querySelector<HTMLButtonElement>('.toggle__btn');
    const body = toggle.querySelector<HTMLElement>('.toggle__body');
    if (!btn || !body) return;

    const open = (animate = true) => {
      toggle.setAttribute('data-open', 'true');
      btn.setAttribute('aria-expanded', 'true');
      body.hidden = false;
      const target = body.scrollHeight;
      if (animate) {
        body.style.height = '0px';
        // force reflow so the transition runs
        void body.offsetHeight;
        body.style.height = target + 'px';
        body.addEventListener('transitionend', function onEnd() {
          body.style.height = 'auto';
          body.removeEventListener('transitionend', onEnd);
        });
      } else {
        body.style.height = 'auto';
      }
    };

    const close = (animate = true) => {
      btn.setAttribute('aria-expanded', 'false');
      if (animate) {
        body.style.height = body.scrollHeight + 'px';
        void body.offsetHeight;
        body.style.height = '0px';
        body.addEventListener('transitionend', function onEnd() {
          toggle.setAttribute('data-open', 'false');
          body.hidden = true;
          body.style.height = '';
          body.removeEventListener('transitionend', onEnd);
        });
      } else {
        toggle.setAttribute('data-open', 'false');
        body.hidden = true;
        body.style.height = '';
      }
    };

    btn.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('data-open') === 'true';
      if (isOpen) close();
      else open();
    });
  });
</script>
