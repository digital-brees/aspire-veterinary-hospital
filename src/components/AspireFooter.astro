---
// AspireFooter.astro — navy footer with real logo, column dividers, contact icons
export interface FooterLink { label: string; href: string; }

export interface Props {
  logoImg?: string;
  quickLinks?: FooterLink[];
  address?: { lines: string[]; mapHref: string };
  email?: string;
  phone?: string;
  hours?: { day: string; time: string }[];
  designByLabel?: string;
  designByHref?: string;
}

const {
  logoImg = 'https://aspirevethospital.com/wp-content/uploads/2025/10/AVH_Dark-BG-logo-200x216-notag.png',
  quickLinks = [
    { label: 'Home', href: '/' },
    { label: 'Our Team', href: '/our-team/' },
    { label: 'Career Opportunities', href: '/careers-germantown-md/' },
    { label: 'Contact', href: '/contact/' },
  ],
  address = {
    lines: ['14112 Darnestown Road,', 'Germantown, MD 20874'],
    mapHref: 'https://maps.app.goo.gl/N2PvSD3aSu1r6CRc9',
  },
  email = 'info@aspirevethospital.com',
  phone = '301-366-0040',
  hours = [
    { day: 'Monday', time: '8am – 6pm' },
    { day: 'Tuesday', time: '8am – 6pm' },
    { day: 'Wednesday', time: '8am – 6pm' },
    { day: 'Thursday', time: '8am – 6pm' },
    { day: 'Friday', time: '8am – 6pm' },
    { day: 'Saturday', time: '9am – 1pm' },
  ],
  designByLabel = 'Digital Empathy',
  designByHref = 'https://digitalempathyvet.com/',
} = Astro.props;
---

<footer class="aspire-footer" id="footer">
  <div class="aspire-footer__inner">
    <div class="aspire-footer__col">
      <a href="/"><img class="aspire-footer__logo-img" src={logoImg} alt="Aspire Veterinary Hospital" /></a>
    </div>

    <div class="aspire-footer__col">
      <h3>Quick Links</h3>
      <ul>
        {quickLinks.map((l) => <li class="no-icon"><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <div class="aspire-footer__col">
      <h3>Contact</h3>
      <ul>
        <li>
          <svg class="aspire-footer__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <a href={address.mapHref} target="_blank" rel="noopener noreferrer">{address.lines.map((line, i) => (<>{line}{i < address.lines.length - 1 && <br />}</>))}</a>
        </li>
        <li>
          <svg class="aspire-footer__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <polyline points="3,7 12,13 21,7"/>
          </svg>
          <a href={`mailto:${email}`}>Email Us</a>
        </li>
        <li>
          <svg class="aspire-footer__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          <a href={`tel:${phone}`}>{phone}</a>
        </li>
      </ul>
    </div>

    <div class="aspire-footer__col">
      <h3>Hours</h3>
      <ul>
        {hours.map((h) => <li class="no-icon">{h.day}: {h.time}</li>)}
      </ul>
    </div>
  </div>

  <div class="aspire-footer__bottom">
    <span>Design by <a href={designByHref} target="_blank" rel="noopener noreferrer">{designByLabel}</a></span>
  </div>
</footer>

<style>
  .aspire-footer {
    background: var(--aspire-navy);
    color: var(--aspire-cream);
    padding: 80px 0 40px;
  }
  .aspire-footer__inner {
    max-width: var(--container);
    margin: 0 auto; padding: 0 32px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 0;
  }
  .aspire-footer__col {
    padding: 0 32px;
    border-right: 1px solid rgba(231,226,216,0.18);
  }
  .aspire-footer__col:first-child { padding-left: 0; }
  .aspire-footer__col:last-child { border-right: none; padding-right: 0; }
  .aspire-footer__logo-img {
    width: 180px;
    height: auto;
    display: block;
  }
  .aspire-footer__col h3 {
    font-family: var(--font-display);
    font-size: 18px; font-weight: 400;
    margin: 0 0 20px;
    color: #fff;
  }
  .aspire-footer__col ul { list-style: none; padding: 0; margin: 0; }
  .aspire-footer__col li {
    margin-bottom: 14px;
    font-size: 14px; line-height: 1.7;
    opacity: 0.9;
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .aspire-footer__col li.no-icon { display: block; }
  .aspire-footer__col li a { color: var(--aspire-cream); text-decoration: none; }
  .aspire-footer__col li a:hover { color: #fff; }
  .aspire-footer__icon {
    flex-shrink: 0;
    width: 16px; height: 16px;
    margin-top: 4px;
    opacity: 0.85;
  }
  .aspire-footer__bottom {
    max-width: var(--container);
    margin: 60px auto 0;
    padding: 24px 32px 0;
    border-top: 1px solid rgba(231,226,216,0.15);
    display: flex; justify-content: flex-end; align-items: center;
    font-size: 12px; opacity: 0.7;
  }
  .aspire-footer__bottom a {
    color: var(--aspire-cream);
    font-family: var(--font-display);
    font-style: italic;
  }
  @media (max-width: 900px) {
    .aspire-footer__inner { grid-template-columns: 1fr 1fr; gap: 32px 0; }
    .aspire-footer__col { border-right: none; padding: 0 16px; }
    .aspire-footer__col:first-child { padding-left: 16px; }
    .aspire-footer__col:last-child { padding-right: 16px; }
  }
  @media (max-width: 560px) {
    .aspire-footer { padding: 60px 0 32px; }
    .aspire-footer__inner { grid-template-columns: 1fr; gap: 28px; }
    .aspire-footer__col { padding: 0; text-align: left; }
    .aspire-footer__logo-img { width: 150px; margin: 0 auto 8px; }
    .aspire-footer__col:first-child { text-align: center; }
    .aspire-footer__bottom { justify-content: center; }
  }
</style>
