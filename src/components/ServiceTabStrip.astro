---
// ServiceTabStrip.astro — sticky tab strip with sibling service links.
// Used on every service page. Mirrors live Avada fusion-tabs styling.
export interface Tab {
  slug: string;
  label: string;
  href: string;
}
export interface Props {
  tabs: Tab[];
  activeSlug?: string;
  ariaLabel?: string;
}
const { tabs, activeSlug, ariaLabel = 'Service navigation' } = Astro.props;
---

<nav class="tab-strip" aria-label={ariaLabel}>
  <div class="tab-strip__inner">
    {tabs.map(tab => (
      <a class={`tab-strip__item${tab.slug === activeSlug ? ' is-active' : ''}`} href={tab.href}>
        {tab.label}
      </a>
    ))}
  </div>
</nav>

<style>
  .tab-strip {
    position: sticky;
    top: 90px;
    z-index: 40;
    background: var(--tab-default-bg);
    position: relative;
  }
  /* Fade-edge scroll cue on mobile: hints there's more to swipe to.
     Hidden on desktop where everything fits. */
  .tab-strip::after {
    content: "";
    display: none;
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 32px;
    background: linear-gradient(to right, rgba(231, 226, 216, 0), rgba(231, 226, 216, 0.95));
    pointer-events: none;
  }
  .tab-strip__inner {
    margin: 0;
    display: flex;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .tab-strip__inner::-webkit-scrollbar { display: none; }
  .tab-strip__item {
    flex: 1 1 0;
    min-width: 140px;
    height: 65px;
    padding: 0 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.2px;
    color: rgb(51, 51, 51);
    background: var(--tab-default-bg);
    text-align: center;
    text-decoration: none;
    line-height: 1.3;
    border-right: 2px solid #fff;
    box-shadow: inset 0 -5px 0 transparent, inset 0 1px 0 transparent;
    transition: background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
  }
  .tab-strip__item:last-child { border-right: none; }
  .tab-strip__item:hover:not(.is-active) {
    background: #fff;
    color: rgb(51, 51, 51);
  }
  .tab-strip__item.is-active {
    background: #fff;
    color: rgb(51, 51, 51);
    box-shadow: inset 0 -5px 0 var(--aspire-tan), inset 0 1px 0 rgb(235, 234, 234);
  }
  @media (max-width: 900px) {
    .tab-strip { top: 60px; }
    .tab-strip::after { display: block; }
    .tab-strip__inner { justify-content: flex-start; }
    .tab-strip__item { font-size: 14px; padding: 14px 10px; min-width: 130px; flex: 0 0 auto; height: auto; }
  }
</style>
