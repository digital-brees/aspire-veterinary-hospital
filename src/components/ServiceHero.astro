---
// ServiceHero.astro — image OR video hero with dark overlay, optional eyebrow + H1 + lede.
// Used on every service page. Fixed 524px min-height to match live.
// Pass `bgVideo` to render an autoplay/loop/muted background video instead of an image;
// `bgImage` is still used as the poster + fallback.
export interface Props {
  bgImage: string;
  bgVideo?: string;
  eyebrow?: string;
  h1: string;
  lede?: string;
}
const { bgImage, bgVideo, eyebrow, h1, lede } = Astro.props;
---

<section class:list={['live-hero', bgVideo && 'live-hero--video']} style={`--hero-bg: url('${bgImage}');`}>
  {bgVideo && (
    <video
      class="live-hero__video"
      src={bgVideo}
      poster={bgImage}
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      aria-hidden="true"
    />
  )}
  <div class="live-hero__overlay" aria-hidden="true"></div>
  <div class="live-hero__inner">
    {eyebrow && <div class="live-hero__eyebrow">{eyebrow}</div>}
    <h1 class="live-hero__h1">{h1}</h1>
    {lede && <p class="live-hero__lede">{lede}</p>}
  </div>
</section>

<style>
  .live-hero {
    --hero-bg: url('https://aspirevethospital.com/wp-content/uploads/2025/10/wellness-care-2_s1.jpg');
    position: relative;
    min-height: 524px;
    background-image: var(--hero-bg);
    background-size: cover;
    background-position: center;
    padding: var(--header-h) 30px 40px;
    text-align: center;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  /* Video variant: image background still acts as poster while video loads. */
  .live-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }
  /* Dark overlay sits on top of bg/video, behind text. */
  .live-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
  }
  .live-hero__inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }
  .live-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.85);
    margin-bottom: 12px;
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-in-up 1s ease 0.15s forwards;
  }
  .live-hero__h1 {
    font-family: var(--font-display);
    font-size: 52px;
    font-weight: 500;
    color: #fff;
    margin-bottom: 16px;
    line-height: 1.15;
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-in-up 1s ease 0.25s forwards;
  }
  .live-hero__lede {
    font-family: var(--font-body);
    font-size: 22px;
    line-height: 1.5;
    color: #fff;
    max-width: 760px;
    margin: 0 auto;
    opacity: 0;
    transform: translateY(20px);
    animation: hero-fade-in-up 1s ease 0.4s forwards;
  }
  @keyframes hero-fade-in-up {
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .live-hero__eyebrow,
    .live-hero__h1,
    .live-hero__lede {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
  @media (max-width: 900px) {
    .live-hero { padding: 110px 20px 56px; min-height: auto; }
    .live-hero__h1 { font-size: 36px; }
    .live-hero__lede { font-size: 17px; }
  }
  @media (max-width: 480px) {
    .live-hero { padding: 96px 18px 44px; }
    .live-hero__h1 { font-size: 30px; }
    .live-hero__lede { font-size: 16px; }
    .live-hero__eyebrow { font-size: 11px; letter-spacing: 2px; }
  }
</style>
