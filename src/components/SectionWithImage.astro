---
// SectionWithImage.astro — text-left + image-right pattern (compact image sidebar).
// Matches live Avada "2/3 + 1/3" column pattern with square image and 20px rounded corners.
// Use this for sections where the image is supporting/illustrative; use SplitSection
// for sections where the framed-portrait image is a hero-equivalent visual element.
export interface Props {
  image: string;
  imageAlt?: string;
  /** When true, the image stays sticky in the viewport on desktop while the
   *  text column scrolls. Disabled on mobile (≤720px) where the image stacks
   *  above the text. */
  sticky?: boolean;
}
const { image, imageAlt = '', sticky = false } = Astro.props;
---

<div class:list={['section-with-image', sticky && 'section-with-image--sticky']}>
  <div class="section-with-image__content">
    <slot />
  </div>
  <div class="section-with-image__image-wrap">
    <img class="section-with-image__img" src={image} alt={imageAlt} loading="lazy" />
  </div>
</div>

<style>
  .section-with-image {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 60px;
    align-items: start;
    margin: 28px 0;
  }
  .section-with-image__content > :first-child { margin-top: 0; }
  .section-with-image__content > :last-child { margin-bottom: 0; }
  .section-with-image__image-wrap {
    text-align: right;
    align-self: start;
  }
  .section-with-image__img {
    width: 100%;
    max-width: 400px;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 20px;
    display: inline-block;
  }

  /* Sticky variant — image stays pinned while long text scrolls (desktop only). */
  .section-with-image--sticky .section-with-image__image-wrap {
    position: sticky;
    /* Sits below the scrolled-state fixed header (~95px) with breathing room. */
    top: 120px;
  }

  @media (max-width: 720px) {
    .section-with-image {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .section-with-image__image-wrap { text-align: center; }
    .section-with-image__img { max-width: 320px; }
    /* Disable sticky on mobile — image stacks above the text instead. */
    .section-with-image--sticky .section-with-image__image-wrap {
      position: static;
    }
  }
</style>
